{
  "name": "pi-topology-network",
  "version": "0.5.0",
  "description": "Pi package for OMP topology network session mesh governance",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "multi-agent",
    "topology",
    "session-mesh"
  ],
  "files": [
    "index.ts",
    "src/**/*.ts",
    "agents/",
    "scripts/",
    "skills/**/SKILL.md",
    "docs/",
    "CHANGELOG.md",
    "RELEASE-NOTES.md",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --experimental-strip-types --test test/integration/*.test.ts",
    "dogfood": "node --experimental-strip-types --test test/integration/dogfood.test.ts",
    "typecheck": "node --experimental-strip-types -e \"await import('./index.ts'); console.log('strip-types import ok')\"",
    "guard-smoke": "node --experimental-strip-types scripts/guard-smoke.mjs",
    "smoke": "npm run test && npm run typecheck && npm_config_cache=/tmp/pi-topology-npm-cache npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  }
}
